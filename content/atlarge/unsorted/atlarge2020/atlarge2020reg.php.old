<?PHP

Initialize();

$go = $_POST["Go"];
if (!$go) {
	$go = $_REQUEST["Go"];
}

if ($go == "Review") {
	ReviewEvent();
	exit;
} elseif ($go == "Check UID") {
	CheckUID();
	exit;
}

/* Beginning of commented section. */

if ($go == "Step Two") {
	Verify_Name_Page(); 
 	DisplayEventForm();
} elseif ($go == "Step Three") {
	Verify_Name_Page();
	DisplayRegistrationSummary();
} elseif ($go == "Complete Registration") {
	Verify_Name_Page();
	Check_for_Duplicate();
	FinalizeRegistration();
} else {
	LogFatalError("Internal Error - yes, really");
}

/* End of comments. */

function Check_for_Duplicate() {
	global $Link, $firstname, $lastname, $email;
	
	$fn = mysql_real_escape_string($firstname,$Link);
	$ln = mysql_real_escape_string($lastname,$Link);
	$em = mysql_real_escape_string($email,$Link);

	$Query =<<<Q
SELECT paid FROM registered WHERE first = "$fn" and last = "$ln" and email = "$em" and cancel="F" and paid="T"
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("Could not access database" . mysql_error());
		
	if (mysql_num_rows($Result) > 0) {
		LogFatalError("$firstname $lastname is already registered.");
	}


}

function Get_Registered_Name($UID) {
	global $Link;
	
	$UID = mysql_real_escape_string($UID,$Link);
	$Query =<<<Q
SELECT first,last,nick,paid FROM registered WHERE UID="$UID" and cancel="F" and paid="T"
Q;
	$Result = mysql_query($Query,$Link) or
		LogFatalError("Could not get registration for $UID" . mysql_error());

	if (mysql_num_rows($Result) > 0) {

		$Row = mysql_fetch_array($Result,MYSQL_ASSOC);
	} else {
		return "";
	}
	
	mysql_free_result($Result);
	
	if ($Row['nick']) {
		$nick = "\"" . $Row['nick'] . "\" ";
	}
	
	$result = $Row['first'] . " $nick" . $Row['last'];
	
	return $result;
}

function ReviewEvent() {
	global $Link, $EventByName, $EventByNumber, $APCount, $HiddenFields;
	
	$TheEvent = $_POST['TheEvent'];
	
	if ($TheEvent == "registrations") {
		$EventName = "Registrations";
		$Query =<<<Q
SELECT * FROM registered ORDER BY UID
Q;
	} else {
		$EventName = $EventByName[$TheEvent];
		$EventName = $EventName['Name'];
		
		$Query =<<<Q
SELECT * FROM registeredevents WHERE Keyword="$TheEvent" ORDER BY UID
Q;
	}
	
	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not get registrations for $TheEvent" . mysql_error());

print <<<P
<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
        "http://www.w3.org/TR/1999/REC-html401-19991224/loose.dtd">
<HTML LANG="en">
<HEAD>
<META http-equiv="content-type" content="text/html; charset=iso-8859-1">
<TITLE>ATLARGE 2020 - $EventName</TITLE>
</HEAD>
<BODY>
    <img src="../wpimages/wpc12a7983_05.jpg" width="230" height="196" border="0" id="pic_2" name="pic_2" title="" alt="">
    <img src="../wpimages/wp17c23015_05.jpg" width="496" height="98" border="0" id="pic_3" name="pic_3" title="" alt=""><br clear=right>
<P>
<P>
<H2>$EventName</H2>
<P>
<OL>
P;
	while ($Row = mysql_fetch_array($Result,MYSQL_ASSOC)) {
		$theName = Get_Registered_Name($Row['UID']);
		if ($theName != "") {
			if ($Row['UID'] != $Row['MasterUID']) {
				$theName .= " (guest of " . Get_Registered_Name($Row['MasterUID']) . ")";
			}
			If ($Row['Option']) {
				$Option = " - " . $Row['Option'];
			} else {
				$Option = "";
			}
			print "<LI>$theName$Option";
		}
	}
	
print <<<P
</OL>
<P>
</BODY></HTML>
P;
}

