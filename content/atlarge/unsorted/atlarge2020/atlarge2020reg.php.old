	$res = mail("$email","Pending ATLARGE Registration",$msg,"From: goldie@atlargepoker.com (ATLARGE Organizers)\n","goldie@atlargepoker.com");

	print <<<P
<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
        "http://www.w3.org/TR/1999/REC-html401-19991224/loose.dtd">
<HTML LANG="en">
