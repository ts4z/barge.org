function LogFatalError($msg) {
    $host = $_SERVER["REMOTE_ADDR"];
    
    $msg = "[client $host] $msg";    
    error_log($msg,0);
    
    FatalError("Fatal Error. $msg");
}

function Initialize() {
	global $Link, $EventByName, $EventByNumber, $APCount, $HiddenFields, $errors;
	
	$HiddenFields = ""; $errors = "";
	
	foreach ($_POST as $key => $value) {
		if (($key != "Go")&&($value != "")) {
			$HiddenFields .=<<<HF
<INPUT TYPE=HIDDEN NAME="$key" VALUE="$value">

HF;
		}
	}
	
	if ($_POST['First3']) {
		$APCount = 3;
	} elseif ($_POST['First2']) {
		$APCount = 2;
	} elseif ($_POST['First1']) {
		$APCount = 1;
	} else {
		$APCount = 0;
	}
	
    # Some day this should change.  No hurry.

    $dbUser = "bargewrite";
    $dbPass = "ZimmersIrwin";
    $dbName = "atlarge2020";
    $dbHost = "localhost";
    
    $Link=mysql_connect($dbHost,$dbUser,$dbPass) or
		LogFatalError("Unable to connect to ATLARGE 2020 Database:" . mysql_error());
		
	mysql_select_db($dbName);

	$Query =<<<Q
SELECT * FROM events ORDER BY eventorder
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not retrieve events " . mysql_error());
		
	while ($Row = mysql_fetch_array($Result,MYSQL_ASSOC)) {
		$Keyword = $Row['Keyword'];
		$subkey = $Row['subkeyword'];
		if ($subkey) {
			$event = $Keyword . "." . $subkey;
		} else {
			$event = $Keyword;
		}
		$eventNumber = $Row['EventOrder'];
		
		$EventByName[$event] = $Row;
		$EventByNumber[$eventNumber] = $Row;
	}

	mysql_free_result($Result);

}

