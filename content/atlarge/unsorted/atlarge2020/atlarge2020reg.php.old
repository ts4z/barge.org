function SendReceipt($kind,$UID) {
	global $email, $firstname, $lastname;
	
	if ($kind == "check") {
		$msg = "Congratulations, we have received your check and you are now registered for ATLARGE 2020.\n\nHere are your registration details:\n\n";
	} elseif ($kind == "credit") {
		$msg = "Congratulations, you have  have successfully  registered for ATLARGE 2020.\n\nHere are your registration details:\n\n";
	}
	
	$msg .= Build_Registration_Entry($UID);
	
	$msg = HTML_to_Text($msg);
	
	$msg .=<<<P

I look forward to seeing you at ATLARGE.

Goldie
P;
# The following message should be moved above "We Look forward..." if
# we get a room block.
#<!-- Hotel reservations may be made by calling the Four Queens at 800-634-6045 and asking for the "tournament" rate.
#The ATLARGE rate is $22/$49 (weekday/weekend) and should be available between 8/2 and 8/7 (subject to change.) -->
# or
#Attendees may secure a room at the Venetian at their regular poker
#room rate.

	
	$res = mail("$email","ATLARGE Registration Receipt",$msg,"From: goldie@atlargepoker.com (ATLARGE Organizers)\n");
	$res = mail("goldie@atlargepoker.com","ATLARGE Registration",$msg,"From: $lastname $firstname <$email>\n");

}	

