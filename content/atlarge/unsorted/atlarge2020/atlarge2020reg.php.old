function Verify_Name_Page() {
	global $name, $emailname, $email, $address, $phone, $accompany,
		$firstname, $lastname, $nickname, $addr1, $addr2, $city, $state,
		$zip, $country, $firstname1, $lastname1, $nickname1, $firstname2,
		$lastname2, $nickname2, $firstname3, $lastname3, $nickname3, $errors;
	
	$Agree = $_POST['Agree'];
	if ($Agree != "yes") {
		LogFatalError("You must agree to the rules in order to register for ATLARGE 2020");
	}
	
    $firstname = Sanitized_Input("First","First name is a required input.",1,'s');
    $lastname = Sanitized_Input("Last","Last name is a required input.",1,'s');
    $nickname = Sanitized_Input("Nick","",0,'s');
    # Trim nickname to 17 characters.
    $name = $firstname . ' ' . $lastname;
    $emailname = "$lastname, $firstname";
    if ($nickname) {
		$name .= " ($nickname)";
    }
    $email = Sanitized_Input("Email","You must supply an E-Mail address.",1,'e');
    $addr1 = Sanitized_Input("Addr1","The first address line is a required input.",1,'s');
    $addr2 = Sanitized_Input("Addr2","",0,'s');
    $city = Sanitized_Input("City","City is a required input.",1,'s');
    $state = Sanitized_Input("State","",0,'s');
    $zip = Sanitized_Input("Zip","A postal code of some sort is required.",1,'s');
    $country = Sanitized_Input("Country","",0,'s');
    $address = "$addr1<BR>";
    if ($addr2) {
		$address .= "$addr2<BR>";
    } 
    $address .= "$city, $state $zip<BR>";
    if ($country) {
		$address .= " $country<BR>";
    }
    $phone = Sanitized_Input("Phone","Phone number is a required input.",1,'s');
    $check = $_POST['Check'];


	if (($_POST['First1'])||($_POST['Last1'])||($_POST['Nick1'])) {
		$firstname1 = Sanitized_Input("First1","You must supply at least a first and last name for an accompanying person.",1,'s');
		$lastname1 = Sanitized_Input("Last1","You must supply at least a first and last name for an accompanying person.",1,'s');
	    $nickname1 = Sanitized_Input("Nick1","",0,'s');
		$accompany = $firstname1 . " " . $lastname1;
		if ($nickname1) {
			$accompany .= " (" . $nickname1 . ")";
		}
    }
	if (($_POST['First2'])||($_POST['Last2'])||($_POST['Nick2'])) {
		if (!$firstname1) {
			LogFatalError("You can't have a second accompanying person without a first.");
		}
		$firstname2 = Sanitized_Input("First2","You must supply at least a first and last name for an accompanying person.",1,'s');
		$lastname2 = Sanitized_Input("Last2","You must supply at least a first and last name for an accompanying person.",1,'s');
	    $nickname2 = Sanitized_Input("Nick2","",0,'s');
		$accompany .= "<BR>" . $firstname2 . " " . $lastname2;
		if ($nickname2) {
			$accompany .= " (" . $nickname2 . ")";
		}
    }
	if (($_POST['First3'])||($_POST['Last3'])||($_POST['Nick3'])) {
		if (!$firstname2) {
			LogFatalError("You can't have a third accompanying person without a second.");
		}
		$firstname3 = Sanitized_Input("First3","You must supply at least a first and last name for an accompanying person.",1,'s');
		$lastname3 = Sanitized_Input("Last3","You must supply at least a first and last name for an accompanying person.",1,'s');
	    $nickname3 = Sanitized_Input("Nick3","",0,'s');
		$accompany .= "<BR>" . $firstname3 . " " . $lastname3;
		if ($nickname3) {
			$accompany .= " (" . $nickname3 . ")";
		}
    }
    PrintErrors();
}

function NameInfoStr() {
	global $name, $emailname, $email, $address, $phone, $accompany;
	
	$nameStr = $name . "<BR>";
	$nameStr .= $address . "<BR>";
	$nameStr .= $email . " ($emailname)<BR>";
	$nameStr .= $phone . "<P>";
	if ($accompany) {
		$nameStr .= "Accompanying Persons:<P>" . $accompany . "<P>";
	}
	
	return $nameStr;
}

function APEventProse($theEvent,$ap) {
	global $theFee;

	$eventName = $theEvent['Name'];
	$eventKey = $theEvent['Keyword'];
	$shorteventKey = substr($eventkey,0,2);
	$eventString = "";
	$guestno = $ap+1;
	$N = "Nick" . $guestno;
	$F = "First" . $guestno;
	if ($_POST[$N]) {
		$GuestName = Sanitized_Input($N,"",0,'s');
	} else {
		$GuestName = Sanitized_Input($F,"",0,'s');
	}
	$eventAPKey = $eventKey . "_" . $guestno;
	$option = $eventKey . "Opt" . "_" . $guestno; 
#	$eventOption = Sanitized_Input($option,"",0,'s');
	$reqOption = $theEvent['reqoption'];
	$eventName = $theEvent['Name'];
	if ($shorteventKey != "so") {
	  $leader = "&nbsp;&nbsp;&nbsp;&nbsp;";
	} else {
	  $leader = "";
	}
		
	if ($_POST[$eventAPKey]) {
		$eventString .=<<<CH
$leader$GuestName: $eventName
CH;
		if ($theEvent['Description']) {
			$eventString .= ", <I>" . $theEvent['Description'] . "</I>";
		}
		
#		if (($reqOption)&&(!$eventOption)) {
#			LogFatalError("The $eventName for $GuestName requires an option to be selected.");
#		}

#		if ($eventOption) {
#			$eventString .= " <B>($eventOption)</B>";
#		}
		if ($theEvent['Fee']>0) {
			$eventString .= ": " . sprintf("\$%0.2f",$theEvent['Fee']) . "<BR>";
			$theFee += $theEvent['Fee'];
		} else {
		  $eventString .= "<BR>";
		}
	}
		
	return $eventString;
}

function SignedUpEventListAsProse() {
	global $EventByNumber, $APCount, $theFee;
	
	$eventString = "Registration: $25.00<BR>";
	
	# Registration fee.
	$theFee = 25;
	
	$i=0;
	while ($i<count($EventByNumber)) {

		$theEvent = $EventByNumber[$i];
		
		$eventKey = $theEvent['Keyword'];
		$eventFee = $theEvent['Fee'];
		$option = $eventKey . "Opt"; 
#		$eventOption = Sanitized_Input($option,"",0,'s');
		$reqOption = $theEvent['reqoption'];
		$eventName = $theEvent['Name'];
				
		$evt = Sanitized_Input($eventKey,"",0,'s');
		if ($evt) {
#			$theFee += $eventFee;
			$eventString .= $theEvent['Name'];
			if ($theEvent['Description']) {
				$eventString .= ", <I>" . $theEvent['Description'] . "</I>";
			}
			
#			if (($reqOption)&&(!$eventOption)) {
#				LogFatalError("The $eventName requires an option to be selected.");
#			}
#			if ($eventOption) {
#				$eventString .= " <B>($eventOption)</B>";
#			}
			
			if ($theEvent['Fee']>0) {
				$eventString .= ": " . sprintf("\$%0.2f",$theEvent['Fee']);
			}
			$eventString .= "<BR>";
		} else {
#		  if ($eventOption) {
#		    LogFatalError("Option selected for $eventKey but $eventKey not selected.");
#		  }
		}
		if ($theEvent['allowguest']) {
			for ($ap=0;$ap<$APCount;$ap++) {
				$eventString .= APEventProse($theEvent,$ap);
			}
		}
		$i++;
	}
	
	$pFee = sprintf("\$%0.2f",$theFee);
	$eventString .= "<BR>Total Fee: $pFee<BR>";
	
	return $eventString;
		
}

