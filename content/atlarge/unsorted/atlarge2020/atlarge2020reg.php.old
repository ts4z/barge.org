}

function Create_Event($UID,$MasterUID,$theEvent,$AP) {
	global $Link;
	
	$eventKey = $theEvent['Keyword'];
	$APeventKey = $eventKey . $AP;
	if (!$_POST[$APeventKey]) {
		return;
	}
	
#	$option = $eventKey . "Opt" . $AP;
#	if ($theEvent['reqoption']) {
#		$eventOpt = Sanitized_Input($option,"",0,'s');
#	}
	$Query =<<<Q
INSERT INTO registeredevents VALUES($UID,$MasterUID,'$eventKey','none')
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not insert event" . mysql_error());


}

function Create_Pending_Registration() {
	global $Link, $name, $emailname, $email, $address, $phone, $accompany,
		$firstname, $lastname, $nickname, $addr1, $addr2, $city, $state,
		$zip, $country, $theFee, $EventByNumber, $APCount, $firstname1,
		$lastname1, $nickname1, $firstname2, $lastname2, $nickname2,
		$firstname3, $lastname3, $nickname3, $EventText, $MasterUID;

	$EventText = SignedUpEventListAsProse();

	$MasterUID = Get_Next_UID(); 
	
	$Query =<<<Q
INSERT INTO registered VALUES($MasterUID,$MasterUID,"$firstname","$lastname",
"$nickname","$addr1","$addr2","$city","$state","$zip","$country","$phone","$email",NULL,
$theFee,'F',NULL,NULL,'F','pending',NULL)
Q;
	
	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not insert pending registration.  MasterUID: $MasterUID " . mysql_error());

	for ($i=0;$i<$APCount;$i++) {
		$sUID = Get_Next_UID();
		$subUID[$i] = $sUID;
		
		$x = $i+1;
		$firstn = "firstname$x";
		$lastn = "lastname$x";
		$nickn = "nickname$x";
		
		$firstn = ${$firstn};
		$lastn = $$lastn;
		$nickn = $$nickn;
		
		$Query =<<<SQ
INSERT INTO registered VALUES($sUID,$MasterUID,"$firstn","$lastn","$nickn","","","","","","","","",NULL,0,'F',NULL,NULL,'F','pending',NULL)
SQ;

		$Result = mysql_query($Query,$Link) or
			LogFatalError("$Query: Could not insert pending registration" . mysql_error());

	}
	
	$i=0;
	while ($i<count($EventByNumber)) {
		$theEvent = $EventByNumber[$i];
		
		$eventKey = $theEvent['Keyword'];
		$allowReg = $theEvent['allowreg'];
		
		if (($_POST[$eventKey])&&($allowReg)) {
			Create_Event($MasterUID,$MasterUID,$theEvent,"");
		}
		
		if (($APCount>0)&&($theEvent['allowguest'])) {
			for ($ap=0;$ap<$APCount;$ap++) {
				$cnt = $ap+1;
				Create_Event($subUID[$ap],$MasterUID,$theEvent,"_$cnt");
			}
		}
		$i++;
	}
	
}

function CompleteRegistration($UID,$Auth,$Trans) {
	global $Link;
	
	$Query =<<<Q
update registered SET timestamp=NULL, Status="complete" where MasterUID="$UID"
Q;
	$Result = mysql_query($Query,$Link) or
			LogFatalError("$Query: Could complete registration" . mysql_error());
	
}

function EventString($theEvent) {
	global $EventByName;
	
	$eventKeyword = $theEvent['Keyword'];
#	$eventOption = $theEvent['Option'];
	$eventMaster = $EventByName[$eventKeyword];
	
 	$eventString = $eventMaster['Time'] . ": " . $eventMaster['Name'];
 	
	if ($eventMaster['Description']) {
		$eventString .= ", " . $eventMaster['Description'];
	}
			
#	if ($eventOption) {
#		$eventString .= " ($eventOption)";
#	}
			
	if ($eventMaster['Fee']>0) {
		$eventString .= ", Fee: " . sprintf("\$%0.2f",$eventMaster['Fee']);
	}
	
	$eventString .= "\n";
	
	return $eventString;
}

function Build_Registration_Entry($UID) {
	global $Link, $email, $firstname, $lastname;
	
	$Query =<<<Q
SELECT * FROM registered WHERE UID="$UID"
Q;
	
	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not get registration for $UID" . mysql_error());
		
	$MasterRow = mysql_fetch_array($Result,MYSQL_ASSOC);

	mysql_free_result($Result);
	
	$namestr = $MasterRow['first'] . " " . $MasterRow['last'];
	if ($MasterRow['nick']) {
		$namestr .= " (" . $MasterRow['nick'] . ")\n";
	} else {
		$namestr .= "\n";
	}
	$namestr .= $MasterRow['addr'] . "\n";
	if ($MasterRow['addr2']) {
		$namestr .= $MasterRow['addr2'] . "\n";
	}
	$namestr .= $MasterRow['city'] . ", " . $MasterRow['state'] . " " . $MasterRow['zip'];
	if ($MasterRow['country']) {
		$namestr .= " " . $MasterRow['country'];
	}
	$namestr .= "\n" . $MasterRow['phone'] . "\n" . $MasterRow['email'] . "\n\nTotal fee paid: " . sprintf("\$%0.2f",$MasterRow['fee']) . "\n";

	$firstname = $MasterRow['first'];
	$lastname = $MasterRow['last'];
	$email = $MasterRow['email'];
	
	$Query =<<<Q
SELECT * FROM registeredevents WHERE UID="$UID"
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not get registration for $UID" . mysql_error());

	$eventlist = "Registration: \$25.00\n";
	
	while ($EventRow = mysql_fetch_array($Result,MYSQL_ASSOC)) {
		
		$eventlist .= EventString($EventRow);
	
	}
	
	if ($MasterRow['paid'] == "F") {
		$paid = " (pending) ";
	}
	if ($MasterRow['cancel'] == "T") {
		$paid = " (cancelled) ";
	}
	

	$outstr = "UID: $UID$paid\n\n" . $namestr . "\n" . $eventlist;
	
	$Query =<<<Q
SELECT * FROM registered WHERE UID!="$UID" and MasterUID="$UID"
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not get AP registration for $UID" . mysql_error());
		
	$APcnt = 0;
	while ($APRow = mysql_fetch_array($Result,MYSQL_ASSOC)) {
		$namestr = $APRow['first'] . " " . $APRow['last'];
		if ($APRow['nick']) {
			$namestr .= " (" . $APRow['nick'] . ")";
		}
		
		$namestr .= "\n";
		
		$apUID = $APRow['UID'];

		$eventlist = "";
		
		$Query =<<<Q
SELECT * FROM registeredevents where UID="$apUID"
Q;
		
		$InnerResult = mysql_query($Query,$Link) or
			LogFatalError("$Query: Could not get AP events for $apUID" . mysql_error());

		while ($APEvent = mysql_fetch_array($InnerResult,MYSQL_ASSOC)) {
			$eventlist .= EventString($APEvent);
		}

		mysql_free_result($InnerResult);	

		$outstr .= "\n" . $namestr . "\n\n" . $eventlist;
		
		$APcnt++;
	}
	
	mysql_free_result($Result);	
	
	return $outstr;
	
}

function Text_to_HTML($str) {

	$str = preg_replace("/\n\n/","<P>",$str);
	$str = preg_replace("/\n/","<BR>",$str);
	$str = preg_replace("/ /","&nbsp;",$str);
	$str = preg_replace("/\[tm\]/","&trade;",$str);
	$str = preg_replace("/<P>/","<P>\n",$str);
	$str = preg_replace("/<BR>/","<BR>\n",$str);
	
	return $str;

}

function HTML_to_Text($str) {
	$str = preg_replace("/<BR>\n/","<BR>",$str);
	$str = preg_replace("/<P>\n/","<P>",$str);
	$str = preg_replace("/<BR>/","\n",$str);
	$str = preg_replace("/<I>/","*",$str);
	$str = preg_replace("|</I>|","*",$str);
	$str = preg_replace("/<B>/","",$str);
	$str = preg_replace("|</B>|","",$str);
	$str = preg_replace("/<P>/","\n\n",$str);
	$str = preg_replace("/&nbsp;/","  ",$str);
	$str = preg_replace("/&trade;/","[tm]",$str);

	return $str;
}

function Get_Next_UID() {
	global $Link;
	
	$Query =<<<Q
LOCK TABLES globals WRITE
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not lock table" . mysql_error());
	
	$Query =<<<Q
SELECT NextUID from globals
Q;
	
	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not get NextUID" . mysql_error());
		
	$Row = mysql_fetch_array($Result,MYSQL_ASSOC);
	
	$UIDno = $Row['NextUID'];
	
	mysql_free_result($Result);
	
	$Query =<<<Q
UPDATE globals SET NextUID=NextUID+1
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not update NextUID" . mysql_error());
		
	$Query =<<<Q
UNLOCK TABLES
Q;

	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not unlock table" . mysql_error());
	
	$Query =<<<Q
SELECT UID FROM regnum WHERE UIDno="$UIDno"
Q;
	
	$Result = mysql_query($Query,$Link) or
		LogFatalError("$Query: Could not get UID" . mysql_error());
		
	$Row = mysql_fetch_array($Result,MYSQL_ASSOC);
	
	$theUID = $Row['UID'];
	
	mysql_free_result($Result);
	
	return $theUID;
	
}

function Get_Fee($UID) {
	global $Link;
	
	$Query =<<<Q
SELECT fee FROM registered WHERE UID="$UID"
Q;
	
	$Result = mysql_query($Query,$Link) or die;
		
	$Row = mysql_fetch_array($Result,MYSQL_ASSOC);
	
	$theFee = $Row['fee'];
	
	mysql_free_result($Result);
	
	return $theFee;

}

function Verify_Email($email) {
    if (strlen($email) > 0) {
		$e = preg_replace("/[0-9A-Za-z]+[0-9A-Za-z\_\-\.]*\@[0-9A-Za-z]+[0-9A-Za-z\_\-\.]*\.[A-Za-z]+$/","",$email);
    }
    if (strlen($e) > 0)  {
		return 0;
    } else {
    	return 1;
    }
}    

function Sanitized_Input($variable,$errorstr,$req,$type) {
	global $Link;

	if ($_POST[$variable]) {
		if ($type == 's') {
			return mysql_real_escape_string($_POST[$variable],$Link);
		} elseif ($type == 'e') {
			if (Verify_Email($_POST[$variable])) {
				return $_POST[$variable];
			} else {
				LogFatalError("il-formed email address.");
			}
		} elseif ($type == 'n') {
			$n = $preg_replace("/^[0-9]+\$/",$_POST[$variable]);
			if ((strlen($n) > 0)&&($n == $_POST[$variable])) {
				return $n;
			} else {
				LogFatalError("il-formed number.");
			}
		} else {
			LogFatalError("Undefined type.");
		}
	} elseif ($req) {
		ErrorMsg($errorstr);
		return "";
	} else {
		return $_POST[$varible];
	}
}

function ErrorMsg($errorstr) {
	global $errors;
	$errors .= "<LI>$errorstr\n";
}

function FatalError($errorstr) {
	global $errors;
	ErrorMsg($errorstr);
	PrintErrors();
}

