function APEvent($theEvent,$ap) {

		$eventTime = $theEvent['Time'];
		$eventName = $theEvent['Name'];
		$eventKey = $theEvent['Keyword'];
		$shorteventKey = substr($eventKey,0,2);
		$eventString = "";
		$guestno = $ap+1;
		$N = "Nick" . $guestno;
		$F = "First" . $guestno;
		if ($_POST[$N]) {
			$GuestName = Sanitized_Input($N,"",0,'s');
		} else {
			$GuestName = Sanitized_Input($F,"",0,'s');
		}
		
#		if ($shorteventKey != "so") {
		if (1) {
		  $eventString .=<<<CH
<TR><TD></TD><TD>
CH;
		} else {
		  $eventString .=<<<CH
<TR><TD>
CH;
			$Interlude = "</td><td>";
		}

		$eventString .=<<<CH
<INPUT TYPE=CHECKBOX NAME="{$eventKey}_$guestno" VALUE="1">$Interlude<B>$GuestName:</B> $eventTime: $eventName
CH;
		if ($theEvent['Description']) {
